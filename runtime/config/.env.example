# =============================================================================
# 必填基础配置
# =============================================================================
# 生产环境请复制为 config/.env 后再填写；不要提交真实 .env。
QQ_BOT_APP_ID=你的QQ机器人AppID
QQ_BOT_APP_SECRET=你的QQ机器人AppSecret

# 至少配置一个被模型路线引用的 Provider API Key。
OPENAI_API_KEY=你的OpenAI_API_Key
DEEPSEEK_API_KEY=
BIGMODEL_API_KEY=
MIMO_API_KEY=

# 天气能力需要和风天气 Key；如果不使用天气，也建议保留占位便于诊断提示明确。
QWEATHER_API_KEY=你的和风天气APIKey
QWEATHER_API_HOST=https://你的和风天气APIHost
QWEATHER_GEO_HOST=

# =============================================================================
# QQ Gateway
# =============================================================================
QQ_BOT_SANDBOX=false
# QQ_BOT_API_BASE=https://api.sgroup.qq.com
QQ_BOT_TOKEN_REFRESH_MARGIN_SECONDS=60

# 默认日志会脱敏；verbose 只用于临时排障，会打印 extracted content。
QQ_MAID_GATEWAY_VERBOSE_LOG=false

# 富媒体发送失败会 fallback 到文本；C2C 最终回复可使用 QQ 流式 Markdown。
QQ_MAID_ENABLE_MARKDOWN=true
QQ_MAID_ENABLE_IMAGE=false
QQ_MAID_C2C_FINAL_REPLY_STREAM_ENABLED=true
# 私聊 Tool Loop 可见进度文本，默认开启；与 QQ 原生 typing 状态相互独立。
QQ_MAID_C2C_VISIBLE_PROGRESS_STATUS_ENABLED=true

# 私聊普通 Agent 请求超过阈值仍未产生用户可见内容时，发送 QQ 原生“正在输入”状态。
QQ_MAID_AGENT_TYPING_ENABLED=true
QQ_MAID_AGENT_TYPING_DELAY_MS=1000
# 私聊工具处理状态提示里的前台称呼；群聊仍使用短提示，避免刷屏。
QQ_MAID_STATUS_DISPLAY_NAME=小女仆

# Gateway 分段软限制，单位为字符数；不是 QQ 平台硬限制。
QQ_MARKDOWN_CHUNK_SOFT_LIMIT=5000
QQ_TEXT_CHUNK_SOFT_LIMIT=5000

# QQ 官方入站图片附件下载缓存。相对路径按 runtime 运行目录解析；不记录完整本地路径到日志。
QQ_MAID_MEDIA_DIR=media/inbound
QQ_MAID_MEDIA_DOWNLOAD_TIMEOUT_MS=10000
# 单张入站图片允许下载与转成 data URL 的最大字节数，默认 10 MiB。
QQ_MAID_MEDIA_MAX_BYTES=10485760

# 群消息处理策略：
# off=忽略；command=只处理 / 命令；mention=命令/@/回复机器人；
# active=额外处理包含指定提示词的普通群消息。
QQ_MAID_GROUP_MESSAGE_MODE=mention
QQ_MAID_GROUP_ACTIVE_KEYWORDS=小女仆
# 普通群事件里的 @ 目标有时不是 AppID。默认会从 Gateway READY 自动学习；
# 若线上日志显示 mention_count>0 仍未命中，可临时填入机器人 openid/member_openid，逗号分隔。
QQ_MAID_BOT_MENTION_IDS=

# =============================================================================
# 微信服务号 Gateway（最小文本同步回复，默认关闭）
# =============================================================================
# 开启后 Gateway 会额外监听 WECHAT_SERVICE_BIND_HOST:WECHAT_SERVICE_BIND_PORT，
# 微信开发者后台回调 URL 指向反向代理后的 WECHAT_SERVICE_CALLBACK_PATH。
# 微信公众平台服务器配置：
# - URL: https://你的域名/wechat/service
# - Token: 与 WECHAT_SERVICE_TOKEN 完全一致
# - 消息加解密方式: 明文模式（当前不支持加密 XML）
# - EncodingAESKey: 当前未使用
# 当前支持 GET URL 验证、POST 明文 text、同步 XML 文本回复；
# 慢请求会在同步预算内结束 HTTP 响应，AppID/AppSecret 已配置时通过客服文本消息补发。
# 不支持模板消息、主动菜单/事件处理、图片语音视频、加密 XML 或流式输出。
# /ping all 只会展示 token/app_id/app_secret 是否 configured，以及 access_token 按需状态，不会打印真实值。
WECHAT_SERVICE_ENABLED=false
# 自定义 Token，用于 signature 校验；不要提交真实值。
WECHAT_SERVICE_TOKEN=
# 配置 AppID / AppSecret 后，慢请求完成时会按需获取 access_token 并调用客服文本消息接口补发。
WECHAT_SERVICE_APP_ID=
WECHAT_SERVICE_APP_SECRET=
# 微信被动回复窗口需预留安全余量，默认 4000ms；最大不超过 4500ms。
WECHAT_SERVICE_REPLY_TIMEOUT_MS=4000
# 正常保持官方 API 域名；本地联调或测试替身才需要改。
# WECHAT_SERVICE_API_BASE=https://api.weixin.qq.com
# 推荐只监听本地回环地址，由反向代理暴露公网 HTTPS。
WECHAT_SERVICE_BIND_HOST=127.0.0.1
WECHAT_SERVICE_BIND_PORT=8788
WECHAT_SERVICE_CALLBACK_PATH=/wechat/service

# =============================================================================
# 会话排队与消息聚合
# =============================================================================
CONVERSATION_QUEUE_CAPACITY=16
MAX_ACTIVE_CONVERSATION_WORKERS=64
CONVERSATION_WORKER_IDLE_TIMEOUT_SECS=300

# 私聊短窗口聚合；命令、pending、/ping、附件和群聊不会被延迟。
MESSAGE_AGGREGATION_PRIVATE_ENABLED=true
MESSAGE_AGGREGATION_GROUP_ENABLED=false
MESSAGE_AGGREGATION_QUIET_MS=1200
MESSAGE_AGGREGATION_MAX_WAIT_MS=3000
MESSAGE_AGGREGATION_MAX_MESSAGES=10
MESSAGE_AGGREGATION_MAX_CHARS=12000
MESSAGE_AGGREGATION_MAX_ACTIVE_KEYS=1024

# =============================================================================
# 模型路由与 Agent 策略
# =============================================================================
# openai / deepseek / bigmodel / auto。
# auto 会按模型候选链中的 provider 前缀路由；未配置 API Key 的 provider 会被跳过。
LLM_PROVIDER=auto

# config/agent.toml 保存非敏感 Agent 策略：私聊/群聊路线、档位、Tool Loop 预算等。
# 默认 agent.toml 不声明普通聊天 [model_routes.*]，以下变量会生成内置路线。
# 如果在 agent.toml 显式声明同名 route，则以 agent.toml 为准。
# API Key、Base URL、真实 prompt 和私有资料仍只能放在 .env 或外部私有目录。
AGENT_CONFIG_FILE=config/agent.toml

# LLM_MODEL 是旧兼容和未显式声明 route 时的基础兜底模型，支持候选链。
# OPENAI_MODEL 是更早版本的兼容默认值；新配置优先使用 LLM_MODEL 或 agent.toml。
OPENAI_MODEL=openai:gpt-5.5
# LLM_MODEL=openai:gpt-5.4-mini
# LLM_MODEL=openai:gpt-5.5,deepseek:deepseek-chat
# LLM_MODEL=bigmodel:glm-5.2,deepseek:deepseek-chat
# LLM_MODEL=mimo:mimo-v2.5-pro,deepseek:deepseek-chat

# 旧兼容：不在 agent.toml 写同名 route 时，可用 .env 按场景覆盖普通聊天。
# 优先级：agent.toml [model_routes.*] > PRIVATE/GROUP_LLM_MODEL > LLM_MODEL > OPENAI_MODEL。
# PRIVATE_LLM_MODEL=openai:gpt-5.5,deepseek:deepseek-chat
# GROUP_LLM_MODEL=openai:gpt-5.4,deepseek:deepseek-chat
# PRIVATE_LLM_MODEL=mimo:mimo-v2.5-pro,deepseek:deepseek-chat
# GROUP_LLM_MODEL=mimo:mimo-v2.5,deepseek:deepseek-chat

# 内部任务模型；留空时沿用 LLM_MODEL。这里同样支持候选链。
TITLE_MODEL=
MEMORY_MODEL=
COMPACT_MODEL=
TRANSLATION_MODEL=
# TODO_MODEL 已废弃；Todo 写操作统一走 Tool Calling。

# /查 使用 OpenAI Responses web_search 兼容模型。
# 优先级：agent.toml [search_routes.*] > PRIVATE/GROUP_OPENAI_SEARCH_MODEL > OPENAI_SEARCH_MODEL。
# OPENAI_SEARCH_MODEL=gpt-5.5
# PRIVATE_OPENAI_SEARCH_MODEL=gpt-5.5
# GROUP_OPENAI_SEARCH_MODEL=gpt-5.5

# =============================================================================
# Provider 参数
# =============================================================================
# OpenAI / OpenAI 兼容接口。
OPENAI_BASE_URL=
# 多地址用逗号分隔；取第一个非空地址，优先级高于 OPENAI_BASE_URL。
OPENAI_BASE_URLS=
# auto 优先 Responses API，必要时降级 Chat Completions。
# GLM / Qwen / Ollama 等只兼容 Chat Completions 的网关请设为 chat_only。
# /查 仍要求 Responses web_search 兼容端点。
OPENAI_API_MODE=auto

# DeepSeek 使用 OpenAI 兼容 Chat Completions 协议。
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek:deepseek-chat

# 智谱 BigModel 使用 OpenAI 兼容 Chat Completions 协议。
BIGMODEL_BASE_URL=https://open.bigmodel.cn/api/paas/v4
BIGMODEL_MODEL=bigmodel:glm-5.2

# =============================================================================
# LLM 调用参数与本地 HTTP 服务
# =============================================================================
LLM_STREAM=true
LLM_REQUEST_TIMEOUT_SECONDS=90
LLM_TTFT_WARN_SECONDS=30
LLM_MAX_OUTPUT_TOKENS=1200
MAX_CONCURRENT_RESPONSES=8

# Tool Loop 默认由 agent.toml 控制；以下变量仅作旧兼容。
# TOOL_CALLING_ENABLED=true
# TOOL_CALLING_GROUP_ENABLED=false
# TOOL_CALLING_MAX_ROUNDS=5

# 聊天链路 trace 默认关闭；开启后需配合 RUST_LOG=trace,qq_maid_core=trace。
LLM_TRACE_CHAT_INPUT=false
LLM_TRACE_CHAT_OUTPUT=false

# 本地上下文字符预算：有效输入上限 = limit - output_reserve。
AGENT_CONTEXT_CHAR_LIMIT=48000
AGENT_CONTEXT_OUTPUT_RESERVE_CHARS=6000
AGENT_CONTEXT_PROTECTED_RECENT_TURNS=4
# 单项 Tool 输出最大字符数；不能低于 18。
AGENT_TOOL_RESULT_CHAR_LIMIT=4000

LLM_SERVER_HOST=127.0.0.1
LLM_SERVER_PORT=8787

# =============================================================================
# 本地 Web 控制台
# =============================================================================
WEB_CONSOLE_ENABLED=false
# 跨域 allowlist，留空表示仅同源；多个 origin 用英文逗号分隔。
WEB_CONSOLE_ALLOWED_ORIGINS=

# =============================================================================
# 数据、Prompt 与知识目录
# =============================================================================
# 相对路径按 runtime 运行目录解析；生产建议使用外部绝对路径。
APP_DB_FILE=data/storage/app.db

# PROMPT_DIR 留空时使用默认 config/prompts；默认目录缺文件会回退内置通用 prompt。
# 显式配置 PROMPT_DIR 后，缺文件或空文件会作为配置错误处理。
PROMPT_DIR=

# Markdown 知识目录；留空时使用 config/knowledge，启动时同步到 SQLite FTS5。
KNOWLEDGE_DIR=

# 外部私有配置示例：
# PROMPT_DIR=/opt/qqbot/private/config/prompts
# KNOWLEDGE_DIR=/opt/qqbot/private/config/knowledge
# APP_DB_FILE=/opt/qqbot/data/app.db

# =============================================================================
# RSS / Atom 订阅
# =============================================================================
RSS_ENABLED=true
RSS_POLL_INTERVAL_SECONDS=300
RSS_HTTP_TIMEOUT_SECONDS=15
RSS_MAX_BODY_BYTES=2097152
RSS_MAX_PUSH_PER_FEED=3
RSS_SUMMARY_MAX_CHARS=500
RSS_SEEN_RETENTION=500
RSS_PUSH_MAX_FAILURES=3
RSS_PUSH_MESSAGE_TYPE=markdown
# 默认拦截 localhost、内网、link-local 和 metadata 地址；仅受控环境可开启。
RSS_ALLOW_PRIVATE_URLS=false

# =============================================================================
# Todo 每日提醒
# =============================================================================
# 只提醒可验证 private target 的个人待办，群待办不会主动推送。
TODO_DAILY_REMINDER_ENABLED=false
# HH:MM 24 小时制，固定按 Asia/Shanghai 解释。
TODO_DAILY_REMINDER_TIME=09:00

# =============================================================================
# 日志
# =============================================================================
RUST_LOG=info,qq_maid_gateway_rs=debug
