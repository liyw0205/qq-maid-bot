target/
dist/
# Web 控制台产物由 Rust 编译期直接嵌入，必须提交；仅忽略本地依赖。
web-console/node_modules/
!web-console/dist/
!web-console/dist/**
__pycache__/
**/__pycache__/
.vscode/
# 本地部署配置，可能包含远端路径或账号信息，不进入 Git。
scripts/deploy.conf
# Compose 实例变量、当前 digest 与部署状态属于本机运行配置。
compose.env
.image.env
deployments/
# 根级历史残留，防止误建。
data/

# 历史目录和误运行路径兜底：这些位置不再是主线配置入口，
# 但一旦残留真实 .env、prompt 或知识库，仍不能进入 Git。
.env
# 真实环境变量文件可能残留在旧模块或误运行子目录，显式兜底避免迁移期误提交。
**/.env
config/.env
config/world.md
config/context_modules.toml
config/prompts/*.md
!config/prompts/*.example.md
config/context/*.md
!config/context/*.example.md
config/knowledge/**/*.md
config/knowledge/**/*.markdown
!config/knowledge/**/*.example.md
!config/knowledge/**/*.example.markdown
llm/.env
llm/config/.env
llm/config/world.md
llm/config/context_modules.toml
llm/config/prompts/*.md
!llm/config/prompts/*.example.md
llm/config/context/*.md
!llm/config/context/*.example.md
llm/config/knowledge/**/*.md
llm/config/knowledge/**/*.markdown
!llm/config/knowledge/**/*.example.md
!llm/config/knowledge/**/*.example.markdown
qq-maid-core/.env
qq-maid-core/config/.env
qq-maid-core/config/world.md
qq-maid-core/config/context_modules.toml
qq-maid-core/config/prompts/*.md
!qq-maid-core/config/prompts/*.example.md
qq-maid-core/config/context/*.md
!qq-maid-core/config/context/*.example.md
qq-maid-core/config/knowledge/**/*.md
qq-maid-core/config/knowledge/**/*.markdown
!qq-maid-core/config/knowledge/**/*.example.md
!qq-maid-core/config/knowledge/**/*.example.markdown
qq-maid-gateway-rs/config/.env

# ========== runtime 运行目录 ==========
# 只提交 README 和 .example 模板；控制台资源已迁移到 web-console/dist 并嵌入二进制。
# 不提交真实配置、运行产物、二进制和部署脚本副本。
runtime/.env
runtime/config/.env
runtime/config/agent.toml
runtime/config/ops.toml
runtime/config/runtime.toml
# 配置中心主密钥及以后新增的本机秘密只存在于持久化运行目录。
runtime/config/secrets/
runtime/config/world.md
runtime/config/context_modules.toml
runtime/config/prompts/*.md
!runtime/config/prompts/*.example.md
runtime/config/context/*.md
!runtime/config/context/*.example.md
runtime/config/knowledge/**/*.md
runtime/config/knowledge/**/*.markdown
!runtime/config/knowledge/**/*.example.md
!runtime/config/knowledge/**/*.example.markdown
runtime/run/
runtime/logs/
runtime/data/
# 二进制与部署脚本副本：由 deploy-remote.sh 从 scripts/ 传入，属于运行时产物。
runtime/qq-maid-bot
runtime/qq-maid-gateway-rs
runtime/qq-maid-llm
runtime/botctl.sh
runtime/botctl.ps1
runtime/botctl.cmd
runtime/validate-runtime.sh
runtime/diagnose-network.sh
runtime/qq-maid-healthcheck.sh
runtime/llmctl.sh
runtime/gatewayctl.sh
runtime/config/knowledge/project_docs/.qq-maid-project-docs-kb
